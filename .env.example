# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=github_analyzer
DB_USER=postgres
DB_PASSWORD=yourpassword

# --- LLM (OpenAI-compatible, must support tool/function calling) ---
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o
LLM_API_KEY=sk-...

# --- Embeddings (local model via sentence-transformers) ---
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# --- GitHub (optional but strongly recommended to avoid rate limits) ---
GITHUB_TOKEN=ghp_...

# --- Agent loop ---
# Hard stop after this many tool calls per session
AGENT_MAX_LOOP=30
# Hard cap on number of distinct file reads per session
AGENT_MAX_FILE_READS=15

# --- App ---
DEBUG=True
SECRET_KEY=change-me-to-a-random-string
ALLOWED_HOSTS=*
